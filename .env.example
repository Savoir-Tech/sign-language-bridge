# =============================================================================
# Sign Language Bridge — Environment Variables
# =============================================================================
# Copy to .env and fill in values. Never commit .env to git.
# For production: use platform secret managers (Vercel, Railway, Render).
# =============================================================================

# --- Backend (Railway/Render) ---

# PostgreSQL (Supabase: use pooler URL, port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Redis (Railway Redis or Render Redis add-on)
REDIS_URL=redis://localhost:6379

# CORS: comma-separated origins (production frontend URL)
CORS_ORIGINS=http://localhost:5173

# JWT: generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-secret-in-production

# AWS Bedrock (Nova Micro, Nova Sonic)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional
ENVIRONMENT=development
BACKEND_PORT=8000
MODEL_PATH=trained_models/best_model.pt
VOCAB_PATH=trained_models/sign_vocab.json
CONFIDENCE_THRESHOLD=0.75
SIGN_CACHE_TTL=3600
TRANSLATION_CACHE_TTL=86400
TTS_CACHE_TTL=86400
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,es,fr

# --- Frontend (Vercel) ---
# Set these in Vercel project settings. For local dev, Vite proxy handles /api and /ws.

# VITE_API_URL=https://your-backend.railway.app
# VITE_WS_URL=wss://your-backend.railway.app
